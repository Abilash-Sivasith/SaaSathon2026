{
  "manifest_version": 3,
  "name": "Screen & Audio Logger",
  "version": "0.2.0",
  "description": "Capture screen, tab audio, and microphone in real time. Logs data locally; ready for backend integration.",
  "permissions": [
    "tabCapture",
    "audioCapture",
    "videoCapture",
    "activeTab",
    "tabs",
    "scripting",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": ""
  },
  "side_panel": {
    "default_path": "dist/popup.html"
  }
}
